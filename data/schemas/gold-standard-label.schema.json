{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gold-Standard Episode Label",
  "description": "Human-verified label for a pipeline episode, used for quality metrics computation.",
  "type": "object",
  "required": ["episode_id", "verified_mode", "verified_reaction_label"],
  "properties": {
    "episode_id": {
      "type": "string",
      "description": "The episode_id from the pipeline episodes table"
    },
    "verified_mode": {
      "type": "string",
      "enum": ["Explore", "Plan", "Implement", "Verify", "Integrate", "Triage", "Refactor"]
    },
    "verified_reaction_label": {
      "type": "string",
      "enum": ["approve", "correct", "redirect", "block", "question", "unknown"]
    },
    "verified_reaction_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "constraint_should_extract": {
      "type": "boolean",
      "description": "Whether this episode should have produced a constraint"
    },
    "notes": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
